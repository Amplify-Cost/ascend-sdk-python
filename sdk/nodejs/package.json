{
  "name": "@ascend/sdk",
  "version": "2.0.0",
  "description": "ASCEND SDK - Enterprise AI Governance with fail mode, circuit breaker, and MCP integration",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "authorization",
    "governance",
    "enterprise",
    "security",
    "compliance",
    "soc2",
    "hipaa",
    "pci-dss",
    "typescript",
    "mcp",
    "circuit-breaker",
    "fail-mode"
  ],
  "author": "ASCEND by OW-AI <support@ascendowkai.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/ascend-sdk-nodejs"
  },
  "homepage": "https://ascendowkai.com",
  "bugs": {
    "url": "https://github.com/anthropics/ascend-sdk-nodejs/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {
    "dotenv": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "dotenv": {
      "optional": true
    }
  }
}
