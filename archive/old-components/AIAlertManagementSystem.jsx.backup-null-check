        </div>
      )}
      {message && (
        <div className="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
          <div className="text-green-800">{message}</div>
        </div>
      )}

      {/* Alert Dashboard Tab */}
      {activeTab === "dashboard" && (
