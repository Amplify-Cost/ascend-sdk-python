# ============================================================================
# OW-kai Enterprise Backend - Environment Configuration
# ============================================================================
#
# SECURITY NOTICE (SEC-079, SEC-080):
# This file documents ALL required environment variables for production.
# DO NOT commit actual secrets to version control.
# Use AWS Secrets Manager, HashiCorp Vault, or similar for production secrets.
#
# Compliance: SOC 2 CC6.1, PCI-DSS 3.5, NIST SP 800-53 SC-12
# ============================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
# Valid values: development, staging, production

# ============================================================================
# CRITICAL SECURITY SECRETS (Required in Production)
# ============================================================================

# Application Secret Key - Used for JWT signing (HS256)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MINIMUM 32 characters required
SECRET_KEY=

# JWT Secret Key (defaults to SECRET_KEY if not set)
JWT_SECRET_KEY=

# Master Encryption Key - Used for encrypting secrets at rest
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_MASTER_KEY=

# Encryption Salt - Used with PBKDF2 key derivation
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(16)).decode())"
ENCRYPTION_SALT=

# ============================================================================
# JWT RS256 KEYS (For EnterpriseJWTManager)
# ============================================================================

# RSA Private Key (PEM format, multiline - use quotes or file path)
# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY=

# RSA Public Key (PEM format)
# Extract with: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY=

# ============================================================================
# DATABASE
# ============================================================================

# Full Database URL (preferred method)
DATABASE_URL=postgresql://postgres:password@localhost:5432/owai_dev

# Or individual components:
DATABASE_HOST=localhost
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=
DATABASE_NAME=owai

# ============================================================================
# AWS CONFIGURATION
# ============================================================================

AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS Secrets Manager (for production secrets storage)
AWS_SECRET_NAME=owkai-pilot/production

# ============================================================================
# AWS COGNITO (Authentication)
# ============================================================================

COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_DOMAIN=

# ============================================================================
# INTEGRATION ENCRYPTION KEYS
# ============================================================================

# ServiceNow Integration Encryption
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SERVICENOW_ENCRYPTION_KEY=

# Notification Service Encryption (Slack/Teams webhooks)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
NOTIFICATION_ENCRYPTION_KEY=

# Notification Service Salt
# Generate with: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(16)).decode())"
NOTIFICATION_ENCRYPTION_SALT=

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# OpenAI API Key (for AI features)
OPENAI_API_KEY=

# Datadog (Observability)
DATADOG_API_KEY=

# Sentry (Error Tracking)
SENTRY_DSN=

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# JWT Token Expiration
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing (OWASP minimum: 12)
BCRYPT_ROUNDS=14

# Algorithm for JWT signing
ALGORITHM=HS256

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://pilot.owkai.app

# Logging
LOG_LEVEL=INFO

# Enterprise Features
ENABLE_ENTERPRISE_FEATURES=true

# ============================================================================
# PRODUCTION REQUIREMENTS CHECKLIST
# ============================================================================
# Before deploying to production, ensure these are configured:
#
# [ ] SECRET_KEY - Minimum 32 characters, no 'dev-' prefix
# [ ] ENCRYPTION_MASTER_KEY - For secrets encryption
# [ ] ENCRYPTION_SALT - For PBKDF2 key derivation
# [ ] JWT_PRIVATE_KEY / JWT_PUBLIC_KEY - For RS256 tokens
# [ ] DATABASE_URL or DATABASE_PASSWORD - Database access
# [ ] SERVICENOW_ENCRYPTION_KEY - If using ServiceNow integration
# [ ] NOTIFICATION_ENCRYPTION_KEY + NOTIFICATION_ENCRYPTION_SALT - If using Slack/Teams
# [ ] COGNITO_* variables - If using AWS Cognito authentication
#
# The application will FAIL TO START if these are missing in production.
# ============================================================================
