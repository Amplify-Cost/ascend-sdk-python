  {
    "id": 197,
    "agent_id": "policy-engine",
    "action_type": "governance_policy",
    "description": "Block all agent actions that would make S3 buckets publicly accessible. Deny by default in production unless explicitly safe.",
    "risk_level": "critical",
    "risk_score": null,
    "status": "active",
    "approved": null,
    "created_at": "2025-10-12T20:39:30.059450",
    "user_id": null,
    "reviewed_at": null,
    "reviewed_by": null,
    "updated_at": "2025-10-12T20:42:31.044714+00:00",
    "approved_by": null,
    "extra_data": {
      "effect": "DENY",
      "actions": [
        "s3:PutBucketAcl",
        "s3:PutObjectAcl",
        "write",
        "modify"
      ],
      "version": 1,
      "conditions": {
        "any_of": [
          {
            "all_of": [
              {
                "field": "environment",
                "value": [
                  "production",
                  "staging"
                ],
                "operator": "in",
                "required": false
              },
              {
                "none_of": [
                  {
                    "field": "acl_confirmed_private",
                    "value": true,
                    "operator": "equals",
                    "required": false
                  },
                  {
                    "field": "security_approved",
                    "value": true,
                    "operator": "equals",
                    "required": false
                  }
                ]
              }
            ]
          },
          {
            "any_of": [
              {
                "field": "acl_contains",
                "value": "public-read",
                "operator": "contains",
                "required": false
              },
              {
                "field": "acl_contains",
                "value": "public-write",
                "operator": "contains",
                "required": false
              },
              {
                "field": "permissions",
                "value": "AllUsers",
                "operator": "contains",
                "required": false
              }
            ]
          }
        ]
      },
      "created_by": "admin@owkai.com",
      "policy_name": "Prevent Public S3 Bucket Access",
      "policy_type": "enterprise_template",
      "template_id": "prevent_public_s3",
