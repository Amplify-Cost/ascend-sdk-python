[
  {
    "field": "risk_level",
    "equals": "low",
    "auto_approve": true
  },
  {
    "field": "action_type",
    "equals": "tool-use",
    "auto_reject": true
  },
  {
    "condition": "log.tool_name == 'AutoGPT'",
    "action": "rejected"
  },
  {
    "condition": "'admin override' in log.description.lower()",
    "action": "pending"
  },
  {
    "condition": "log.risk_level == 'low'",
    "action": "approved"
  }
]