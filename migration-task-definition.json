{
  "family": "owkai-pilot-migration",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::110948415588:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::110948415588:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "migration",
      "image": "PLACEHOLDER_IMAGE",
      "essential": true,
      "command": ["sh", "-c", "cd /app && PYTHONPATH=/app alembic downgrade base && PYTHONPATH=/app alembic upgrade head"],
      "environment": [],
      "secrets": [
        {"name": "DATABASE_URL", "valueFrom": "arn:aws:secretsmanager:us-east-2:110948415588:secret:/owkai/pilot/backend/DB_URL-RuZYGO"},
        {"name": "SECRET_KEY", "valueFrom": "arn:aws:secretsmanager:us-east-2:110948415588:secret:/owkai/pilot/backend/JWT_SECRET-G7tAIB"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/owkai-pilot-migration",
          "awslogs-region": "us-east-2",
          "awslogs-stream-prefix": "migration"
        }
      }
    }
  ]
}
